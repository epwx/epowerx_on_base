# Biconomy Exchange API Configuration
BICONOMY_EXCHANGE_API_KEY=your-api-key-here
BICONOMY_EXCHANGE_API_SECRET=your-api-secret-here
BICONOMY_EXCHANGE_BASE_URL=https://www.biconomy.com/api

# Trading Configuration
TRADING_PAIR=EPWX/USDT
EPWX_TOKEN_ADDRESS=0xeF5f5751cf3eCA6cC3572768298B7783d33D60Eb

# Volume Generation Strategy
VOLUME_TARGET_DAILY=50000            # Target daily volume in USD (profitable target)
MIN_ORDER_SIZE=5                     # Minimum order size in USD
MAX_ORDER_SIZE=20                    # Maximum order size in USD
SPREAD_PERCENTAGE=0.2                # Tight spread for profitable MM (0.2%)
ORDER_FREQUENCY=300000               # Place orders every 5 minutes (300 seconds)
SELF_TRADE_ENABLED=false             # Let market naturally fill orders
WASH_BASE_PAIRS_PER_CYCLE=5          # Minimum wash pairs attempted per cycle
WASH_MAX_PAIRS_PER_CYCLE=12          # Upper cap for wash pairs per cycle
WASH_RESERVED_PLACEMENTS_PER_CYCLE=10 # Reserve order slots each cycle for wash trades
WASH_USDT_SCALE_THRESHOLD=1500       # Add 1 wash pair per this much available USDT
WASH_ORDER_SIZE_CAP_USD=35           # Per-wash-order USD cap (still balance-aware)
MAX_ORDER_AMOUNT_TOKENS=50000000000  # Hard cap for EPWX amount per single order
PAUSE_WASH_ON_HIGH_DRIFT=true        # Pause wash trades if DEX/CEX price drift is too high
MAX_DEX_CEX_DRIFT_PERCENT=20         # Drift threshold (%) for wash-trade pause guard

# Market Making Parameters
MAX_POSITION_SIZE=5000              # Maximum position to accumulate
POSITION_REBALANCE_THRESHOLD=1000   # Rebalance when position exceeds this
UPDATE_INTERVAL=3000                # Update every 3 seconds

# Risk Management
MAX_SLIPPAGE=0.5                    # Maximum slippage tolerance (%)
DAILY_LOSS_LIMIT=1000               # Stop if daily loss exceeds (USD)
ENABLE_POSITION_LIMITS=false        # Disable for volume generation

# Logging
LOG_LEVEL=info
